# ----------------------------------------------------------------------------
# Senso environment configuration.
# Copy to `.env.local` and fill values. EVERYTHING degrades gracefully when a
# block is left empty: with no Supabase, leaderboards fall back to a local
# (device-only) board; with no AdSense client, no ads load; with no Stripe,
# the premium upgrade UI is hidden. The games, sharing and i18n always work.
# ----------------------------------------------------------------------------

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Senso
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supabase (leaderboards, auth, premium flag). Leave blank to run fully offline.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AdSense (content surfaces only). Leave blank to disable ads.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=

# Ko-fi donations
NEXT_PUBLIC_KOFI_HANDLE=yourhandle

# Stripe (premium subscriptions). Leave blank to hide upgrade UI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=
